{
  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".validate": "auth.uid !== $uid || !newData.child('role').exists() || newData.child('role').val() === data.child('role').val()"
      }
    },

    "vacancies": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "candidates": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "tags": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },

    "settings": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "analytics": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}
